# ============================================================
#  STORE — Environment Configuration Template
# ============================================================
#  Copy this file to .env and fill in your real credentials.
#  This .env.example file is SAFE to commit to version control.
# ============================================================

# Application Environment: "development" or "production"
APP_ENV=development

# ── URLs ──────────────────────────────────────────────────────
# Local XAMPP:                  SITE_URL=/store
# Hostinger root domain:        SITE_URL=https://jevarmart.com
# Hostinger subdirectory:       SITE_URL=/yourfolder
SITE_URL=https://jevarmart.com

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_PORT=3306

# ── SMTP / Email ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_PORT=465
SMTP_SECURE=ssl
MAIL_FROM_NAME=Your Store Name
